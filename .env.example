# ─────────────────────────────────────────────────────────────────────────────
# SkepticalWombat — Environment Variables
# Copy this file to .env.local and fill in every value before running locally.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── xAI (Grok) ───────────────────────────────────────────────────────────────
# Get your key at: https://console.x.ai
XAI_API_KEY=xai-...

# Optional: override the default model (grok-4.3).
# Set to grok-4-1-fast-reasoning if you have access.
# XAI_MODEL=grok-4.3

# ── Google Gemini (transcription — default provider) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── OpenAI (optional: Whisper transcription) ──────────────────────────────────
# Set TRANSCRIPTION_PROVIDER=whisper to use OpenAI instead of Gemini.
# Model: gpt-4o-transcribe (default) or whisper-1. Override with WHISPER_MODEL.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# TRANSCRIPTION_PROVIDER=whisper
# WHISPER_MODEL=gpt-4o-transcribe

# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Your pooled connection string from the Neon console.
# Format: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://...

# ── Stack Auth ────────────────────────────────────────────────────────────────
# Create a project at: https://app.stack-auth.com
# Then copy the three keys from your project's API Keys tab.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
# Full URL of your deployment (used for OG metadata, Stack Auth redirect URLs).
# Local: http://localhost:3000
# Prod:  https://your-domain.vercel.app
APP_URL=http://localhost:3000
